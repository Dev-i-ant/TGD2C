// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(cuid())
  telegramId   String        @unique
  username     String?
  points       Int           @default(0)
  tradeUrl     String?
  inventory    Reward[]
  tasks        UserTask[]
  transactions Transaction[]
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Historical Records
  bestItemName   String?
  bestItemRarity String?
  bestItemImage  String?
  bestItemWeight Int           @default(0)
  bestItemPrice  Int           @default(0)

  // Titles & Customization
  titles           String?     // Comma-separated or JSON string for user badges

  // Referral System
  referralCode     String?     @unique @default(cuid())
  referredById     String?
  referredBy       User?       @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]      @relation("Referrals")
  referralCount    Int         @default(0)
  referralEarnings Int         @default(0)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fromUserId  String?  // Optional: The user who generated this transaction (e.g. friend)
  amount      Int
  type        String // 'TASK_REWARD', 'CASE_OPEN', 'ADMIN_ADJUST', 'REFERRAL_BONUS', 'REFERRAL_COMMISSION'
  description String
  createdAt   DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String
  points      Int
  type        String     // e.g., "SUBSCRIPTION"
  channelId   String?    // For subscription tasks
  users       UserTask[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserTask {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  user        User     @relation(fields: [userId], references: [id])
  task        Task     @relation(fields: [taskId], references: [id])
  completedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, taskId])
}

model Case {
  id          String   @id @default(cuid())
  name        String
  price       Int
  image       String?
  color       String   @default("bg-blue-500")
  rarity      String   @default("RARE")
  rewards     Reward[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reward {
  id        String   @id @default(cuid())
  name      String
  rarity    String   // e.g., "COMMON", "RARE", "LEGENDARY"
  image     String?
  weight    Int      // Drop chance weight
  sellPrice Int?     // Optional custom sell price
  status    String   @default("IN_STOCK") // "IN_STOCK", "SOLD", "WITHDRAWN"
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String?
  owner     User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalItem {
  id        String   @id @default(cuid())
  name      String   @unique
  rarity    String
  image     String?
  sellPrice    Int?
  defaultWeight Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt
}
